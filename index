            box.classList.add("status-successo");
            titolo.innerText = "Soluzione Iscrizione Dante Alighieri: ad euro 1780 + 16 di marca da bollo (Standard)";
            testo.innerHTML = "buono Amazon € 30 - ISCRIVITI CON IL CODICE RISERVATO <span style='color:#0f5132; background:#d1e7dd; padding:2px 6px; border-radius:3px;'>MT30</span><br><span style='font-weight:normal; font-size:14px;'>CON Università Dante Alighieri di Reggio Calabria</span><br><a href='" + linkDanteAlighieri + "' target='_blank' class='btn-link-iscrizione'>PER ISCRIVERTI CLICCA QUI!</a>";
            return;
        }
    }

    // FALLBACK GENERALE: Se nessuna promozione specifica è attiva (Rimanda a UniCamillus standard con codice MT30)
    box.className = "risultato-box-iscrizioni status-generico";
    titolo.innerText = "Iscriviti ad Unicamillus ad euro 1690 + 16 usa il Codice Riservato MT30";
    testo.innerHTML = "Buono Amazon € 30 - ISCRIVITI CON IL CODICE RISERVATO <span style='color:#004085; background:#b8daff; padding:2px 6px; border-radius:3px;'>MT30</span><br><span style='font-weight:normal; font-size:14px;'>promozione buono amazon attiva per questa combinazione. Puoi utilizzare il codice riservato mt30 per procedere.</span><br><a href='" + linkUniCamillus + "' target='_blank' class='btn-link-iscrizione'>PER ISCRIVERTI CLICCA QUI!</a>";
