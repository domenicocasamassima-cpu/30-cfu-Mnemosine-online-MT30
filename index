    ];

    const classiUnitelma = [
        "A12", "A18", "A20", "A21", "A26", "A27", "A45", "A46", "A48", "AB22", "A60"
    ];

    box.style.display = "block";

    // --- LINK EDITABILI ---
    const linkUniCamillus = "https://www.formazionedocenti.it/corso-online-mnemosine/UM30CFU";
    const linkDanteAlighieri = "https://www.formazionedocenti.it/corso-online-mnemosine/RC30CFUART13";
    const linkConservatorio = "https://www.formazionedocenti.it/corso-online-mnemosine/CM30CFUART13";
    const linkUnitelma = "https://www.formazionedocenti.it/corso-online-mnemosine/UNT30CFU";

    // --- ESECUZIONE DELLE REGOLE CONDIZIONALI ---

    // REGOLA Conservatorio: Abilitazione discipline musicali del conservatorio
    if (sit === "musicali") {
        box.classList.add("status-successo");
        titolo.innerText = "Soluzione Iscrizione: Conservatorio ad euro 1780 + 16 di marca da bollo";
        testo.innerHTML = "Buono Amazon €30 - ISCRIVITI CON IL CODICE RISERVATO <span style='color:#055160; background:#cff4fc; padding:2px 6px; border-radius:3px;'>MT30</span><br><span style='font-weight:normal; font-size:14px;'>CON il Conservatorio Statale di Musica “P.I.Tchaikovksy” di Nocera Terinese (CZ)</span><br><a href='" + linkConservatorio + "' target='_blank' class='btn-link-iscrizione'>PER ISCRIVERTI CLICCA QUI!</a>";
        return;
    }

    // CASISTICA A: L'utente ha selezionato "Specializzazione Sostegno"
    if (sit === "sostegno") {
        // Controllo prioritario per classi A21 e A46 con Sostegno (Unitelma)
        if (cls === "A21" || cls === "A46") {
            box.classList.add("status-successo");
            titolo.innerText = "Soluzione Iscrizione: Unitelma Sapienza ad euro 1650 + 16 di marca da bollo";
            testo.innerHTML = "SCONTO € 130 - ISCRIVITI CON Università Unitelma e IL CODICE RISERVATO <span style='color:#0f5132; background:#d1e7dd; padding:2px 6px; border-radius:3px;'>MT30UNITELMA</span> per lo sconto di € 130<br><a href='" + linkUnitelma + "' target='_blank' class='btn-link-iscrizione'>PER ISCRIVERTI CLICCA QUI!</a>";
            return;
        }
        else if (classiUniCamillus.includes(cls)) {
            box.classList.add("status-successo");
            titolo.innerText = "Soluzione Iscrizione: UniCamillus ad euro 1590 + 16 di marca da bollo";
            testo.innerHTML = "SCONTO € 100 - ISCRIVITI CON IL CODICE RISERVATO <span style='color:#0f5132; background:#d1e7dd; padding:2px 6px; border-radius:3px;'>MT30TFA25</span><br><span style='font-weight:normal; font-size:14px;'>CON UNICAMILLUS</span><br><a href='" + linkUniCamillus + "' target='_blank' class='btn-link-iscrizione'>PER ISCRIVERTI CLICCA QUI!</a>";
            return;
        } 
        else if (classiDanteAlighieri.includes(cls)) {
            box.classList.add("status-successo");
            titolo.innerText = "Soluzione Iscrizione: Dante Alighieri ad euro 1680 + 16 di marca da bollo";
            testo.innerHTML = "SCONTO € 100 - ISCRIVITI CON IL CODICE RISERVATO <span style='color:#0f5132; background:#d1e7dd; padding:2px 6px; border-radius:3px;'>MT30TFA25</span> per lo sconto di € 100<br><span style='font-weight:normal; font-size:14px;'>CON Università Dante Alighieri di Reggio Calabria</span><br><a href='" + linkDanteAlighieri + "' target='_blank' class='btn-link-iscrizione'>PER ISCRIVERTI CLICCA QUI!</a>";
            return;
        }
    }

    // CASISTICA B: L'utente ha selezionato "Nessuna delle precedenti"
    if (sit === "nessuna") {
        if (classiUnitelma.includes(cls)) {
            box.classList.add("status-successo");
            titolo.innerText = "Soluzione Promo Unitelma Sapienza: ad euro 1650 + 16 di marca da bollo";
