<script>
function elaboraAlgoritmoIscrizione() {
    const sit = document.getElementById("situazioneIscrizione").value;
    const cls = document.getElementById("classeIscrizione").value;
    const box = document.getElementById("boxRisultatoIscrizione");
    const titolo = document.getElementById("titoloRisultatoIscrizione");
    const testo = document.getElementById("testoRisultatoIscrizione");

    // Reset Box
    box.style.display = "none";
    box.className = "risultato-box-iscrizioni";

    // Validazione input vuoti
    if (!sit || !cls) {
        box.style.display = "block";
        box.classList.add("status-errore");
        titolo.innerText = "Campi incompleti";
        testo.innerText = "Per favore, seleziona sia la tua situazione che la classe di concorso.";
        return;
    }

    // ARRAYS DI MAPPATURA CLASSI
    const classiUniCamillus = [
        "A12", "A15", "A18", "A19", "A20", "A26", "A27", "A28", "A31", "A34", 
        "A40", "A41", "A42", "A45", "A47", "A48", "A50", "A51", "A60", "AB22", 
        "B003", "B012", "B016", "B020", "B021"
